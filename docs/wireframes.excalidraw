      "boundElements": [],
      "updated": 1774357007924,
      "link": null,
      "locked": false,
      "text": "Hors km en abandon. En\nfaisant un don à l'association\nde certaines de vos dépenses,\nvous participer à la\ncontinuation de ses services.\nVos dons seront pris en\ncompte lors des impôts.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "WdKG8n-a6FcZF4BWFovs_",
      "originalText": "Hors km en abandon. En faisant un don à l'association de certaines de vos dépenses, vous participer à la continuation de ses services.\nVos dons seront pris en compte lors des impôts.",
      "autoResize": true,
      "lineHeight": 1.25
    },
